typeset -U PATH
typeset -U path
eval $(/opt/homebrew/bin/brew shellenv)
export CFLAGS="-I${HOMEBREW_PREFIX}/opt/openssl/include"
export LDFLAGS="-L${HOMEBREW_PREFIX}/opt/openssl/lib"
autoload -Uz compinit
# Only rebuild completion dump once a day; skip compaudit the rest of the time
if [[ -n ${HOME}/.zcompdump(#qN.mh+24) ]]; then
    compinit
else
    compinit -C
fi
autoload -U +X bashcompinit && bashcompinit
if [[ "${ZSHENV_LOADED:="BLA"}" = "BLA" ]]; then
    source $HOME/.zshenv
fi
source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
export TERM=xterm-256color
#export TERM=xterm-kitty
export HOMEBREW_CASK_OPTS="--appdir=/Applications"
export BROWSE=open
export CLIPBOARD='pbcopy'
export PASTE='pbpaste'

dashush()
{
    open "dash://$@"
}

alias flushdns='(
    dscacheutil -flushcache
    sudo killall -HUP mDNSResponder
    sudo killall -9 mDNSResponder mDNSResponderHelper
    sudo launchctl stop homebrew.mxcl.dnsmasq
    sudo launchctl start homebrew.mxcl.dnsmasq
    echo "DNS cache cleared — also check chrome://net-internals/#dns if needed"
)'

preview()
{
    qlmanage -p "$@" >& /dev/null &
}

what-year-is-it()
{
    softwareupdate -l --product-type macOS
    mas outdated
    brew update
    brew upgrade
    brew cleanup -s
    antidote update
    tldr --update
    nvim --headless "+Lazy! sync" +qa
    nvim --headless -c 'UpdateRemotePlugins | qa'
    nvim --headless -c 'TSUpdateSync | qa'
}

export MANPATH="$HOMEBREW_PREFIX/opt/coreutils/libexec/gnuman:${MANPATH}"
source ${DOTFILESDIR}/zsh/zshrc

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

command -v terraform >/dev/null && complete -o nospace -C "$(which terraform)" terraform

if command -v op >/dev/null; then
    local _op_comp="${HOMEBREW_PREFIX}/share/zsh/site-functions/_op"
    [[ -f $_op_comp ]] || op completion zsh > "$_op_comp"
    compdef _op op
fi

# tabtab source for packages
# uninstall by removing these lines
[[ -f ~/.config/tabtab/__tabtab.zsh ]] && . ~/.config/tabtab/__tabtab.zsh || true
export PATH=${HOMEBREW_PREFIX}/bin:${DOTFILESDIR}/bin-mac:${GOPATH}/bin:${HOMEBREW_PREFIX}/opt/coreutils/libexec/gnubin:/usr/local/cli-plugins:${HOME}/.bin:${HOME}/.local/bin:${PYENV_ROOT}/shims:$PATH
#NODE_VERSION=$(node --version)
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
export PYENV_VIRTUALENV_DISABLE_PROMPT=1
# Lazy-load pyenv — shims are ~430ms; only pay that cost when Python is first used
_pyenv_init() {
    unfunction python python3 pip pip3 pyenv tmuxp 2>/dev/null
    eval "$(pyenv init -)"
    eval "$(pyenv virtualenv-init -)"
}
for _cmd in python python3 pip pip3 pyenv tmuxp; do
    eval "function ${_cmd}() { _pyenv_init; ${_cmd} \"\$@\"; }"
done
unset _cmd

c () {
  if [ -f .claude_session ]; then
      local cmd session_id encoded_cwd session_file claude_dir
      cmd=$(cat .claude_session)
      session_id=$(echo "$cmd" | sed -n 's/.*--resume[[:space:]]\+\([^ ]*\).*/\1/p')
      if [ -n "$session_id" ]; then
          claude_dir="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
          encoded_cwd=$(pwd | sed 's/[^a-zA-Z0-9]/-/g')
          session_file="$claude_dir/projects/$encoded_cwd/$session_id.jsonl"
          if [ -f "$session_file" ]; then
              rm -f .claude_session
              eval "$cmd"
              return
          fi
      fi
      rm -f .claude_session
      claude "$@"
  else
      claude "$@"
  fi
}

#TODO wrap c for private/work
alias claude-personal='CLAUDE_CONFIG_DIR=~/.claude-personal c'

# Personal Account (default profile in ~/.gemini)
alias gemp='gemini'

# Work Account (separate profile in ~/.gemini-work)
alias gemw='GEMINI_CLI_HOME=~/.gemini-work gemini'

# Resume the session from the local .gemini_session file
alias gemr='[ -f .gemini_session ] && eval $(cat .gemini_session) || echo "No .gemini_session file found."'
